---
const categories = [
  { key: 'all', label: 'All' },
  { key: 'decision-log', label: 'Decision Logs' },
  { key: 'framework', label: 'Frameworks' },
  { key: 'guide', label: 'Guides' },
  { key: 'note', label: 'Notes' },
];
---

<div class="filter-row reveal reveal-delay-1">
  {
    categories.map((cat) => (
      <button class={`filter-tag ${cat.key === 'all' ? 'active' : ''}`} data-filter={cat.key}>
        {cat.label}
      </button>
    ))
  }
</div>

<script>
  const filterTags = document.querySelectorAll('.filter-tag');
  const cards = document.querySelectorAll('.blog-card');

  filterTags.forEach((tag) => {
    const btn = tag as HTMLElement;
    btn.addEventListener('click', () => {
      filterTags.forEach((t) => t.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      cards.forEach((card) => {
        const el = card as HTMLElement;
        el.style.display =
          filter === 'all' || el.dataset.category === filter ? 'block' : 'none';
      });
    });
  });
</script>
