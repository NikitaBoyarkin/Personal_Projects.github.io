---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import InnerTOC from '../../components/InnerTOC.astro';
import { withBase } from '../../lib/path';

export async function getStaticPaths() {
  const projects = await getCollection('projects', (p) => !p.data.draft);
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.md$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Base
  title={`${project.data.title} | Nikita Boyarkin`}
  description={project.data.description}
  ogType="article"
  activeNav="home"
  canonical={withBase(`projects/${project.id.replace(/\.md$/, '')}/`)}
>
  <InnerTOC />

  <div class="container reveal">
    <a class="back" href={withBase('/')}>← Back to portfolio</a>

    {
      project.data.hero && (
        <img
          id="project-image"
          class="hero-image"
          src={withBase(project.data.hero)}
          alt={`${project.data.title} preview`}
          width="1200"
          height="600"
        />
      )
    }

    <div class="project-meta">
      {
        project.data.tools && project.data.tools.length > 0 && (
          <div class="project-meta-group">
            <span class="project-meta-label">Stack</span>
            <div class="project-tools project-tools-inline">
              {project.data.tools.map((tool) => (
                <span class="project-tool">{tool}</span>
              ))}
            </div>
          </div>
        )
      }

      {
        project.data.impact && project.data.impact.length > 0 && (
          <div class="project-meta-group">
            <span class="project-meta-label">Impact</span>
            <ul class="project-meta-list">
              {project.data.impact.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        )
      }

      {
        project.data.github && (
          <div class="project-meta-group">
            <span class="project-meta-label">Source</span>
            <a
              class="project-meta-link"
              href={project.data.github}
              target="_blank"
              rel="noopener noreferrer"
            >
              View on GitHub →
            </a>
          </div>
        )
      }
    </div>

    <article id="project-content">
      <Content />
    </article>
  </div>
</Base>
